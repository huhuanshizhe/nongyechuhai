{
  "name": "nongyechuhai",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "node tools/dev-help.mjs",
    "dev:web": "node tools/dev-app.mjs @nongyechuhai/web",
    "dev:admin": "node tools/dev-app.mjs @nongyechuhai/admin",
    "dev:supplier": "node tools/dev-app.mjs @nongyechuhai/supplier",
    "images:generate": "tsx tools/generate-product-images.ts",
    "build": "corepack pnpm -r --if-present run build",
    "lint": "corepack pnpm -r --if-present run lint",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "corepack pnpm --filter @nongyechuhai/db db:generate",
    "db:migrate": "corepack pnpm --filter @nongyechuhai/db db:migrate",
    "db:seed": "corepack pnpm --filter @nongyechuhai/db db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "get-port": "^7.1.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
